<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: #0f0f1a;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.example.f1trvia.HelloController">

    <VBox fx:id="menuScreen" alignment="CENTER" spacing="14" style="-fx-background-color: #f5f5f5;">
        <padding><Insets bottom="30" left="60" right="60" top="30" /></padding>

        <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #e10600;" text="F1 TRIVIA EXPERIENCE" />
        <Label style="-fx-font-size: 13px; -fx-text-fill: #e10600;" text="Choose your race, year and sessions" />

        <Separator style="-fx-background-color: #333;" />

        <Label style="-fx-text-fill: #e10600; -fx-font-size: 13px;" text="Select Year:" />
        <ComboBox fx:id="yearBox" prefWidth="280" style="-fx-background-color: #1e1e2e; -fx-text-fill: white;" />

        <Label style="-fx-text-fill: #e10600; -fx-font-size: 13px;" text="Select Circuit:" />
        <ComboBox fx:id="circuitBox" prefWidth="280" style="-fx-background-color: #1e1e2e; -fx-text-fill: white;" />
        <Label fx:id="circuitStatusLabel" style="-fx-text-fill: #f39c12; -fx-font-size: 11px;" text="" />

        <Label style="-fx-text-fill: #e10600; -fx-font-size: 13px;" text="Select Practice Sessions:" />
        <HBox alignment="CENTER" spacing="20">
            <CheckBox fx:id="fp1Check" style="-fx-text-fill: #e10600;" text="FP1" />
            <CheckBox fx:id="fp2Check" style="-fx-text-fill: #e10600;" text="FP2" />
            <CheckBox fx:id="fp3Check" style="-fx-text-fill: #e10600;" text="FP3" />
        </HBox>

        <Label style="-fx-text-fill: #e10600; -fx-font-size: 13px;" text="Select Difficulty:" />
        <ComboBox fx:id="difficultyBox" prefWidth="280" style="-fx-background-color: #1e1e2e; -fx-text-fill: white;" />

        <Label fx:id="highScoreLabel" style="-fx-text-fill: #e10600; -fx-font-size: 13px;" text="High Score: --" />

        <Button onAction="#onStartQuiz" prefHeight="45" prefWidth="200" style="-fx-background-color: #e10600; -fx-text-fill: white;                        -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;" text="START QUIZ" />

        <Label style="-fx-text-fill: #555; -fx-font-size: 11px;" />
    </VBox>

    <VBox fx:id="loadingScreen" alignment="CENTER" spacing="20" style="-fx-background-color: #f5f5f5;" visible="false">
        <Label style="-fx-font-size: 22px; -fx-text-fill: #e10600;" text="⏳  Loading..." />
        <Label fx:id="loadingLabel" style="-fx-text-fill: #aaaaaa; -fx-font-size: 13px;" text="Fetching F1 data..." />
        <ProgressIndicator style="-fx-progress-color: #e10600;" />
    </VBox>

    <VBox fx:id="quizScreen" alignment="TOP_CENTER" spacing="14" style="-fx-background-color: #f5f5f5;" visible="false">
        <padding><Insets bottom="25" left="50" right="50" top="25" /></padding>

        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label fx:id="questionNumberLabel" style="-fx-text-fill: #e10600; -fx-font-size: 12px;" text="Question 1 / 10" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="scoreLabel" style="-fx-text-fill: #e10600; -fx-font-size: 14px; -fx-font-weight: bold;" text="Score: 0" />
        </HBox>

        <ProgressBar fx:id="progressBar" prefWidth="600" progress="0" style="-fx-accent: #e10600;" />

        <Label fx:id="questionLabel" prefWidth="600" style="-fx-font-size: 18px; -fx-text-fill: #e10600; -fx-font-weight: bold; -fx-padding: 20 0 10 0;" text="Question text here" wrapText="true" />

        <Button fx:id="choiceA" onAction="#onChoiceA" prefHeight="50" prefWidth="600" style="-fx-background-color: #fc0c05; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand;" text="A" wrapText="true" />
        <Button fx:id="choiceB" onAction="#onChoiceB" prefHeight="50" prefWidth="600" style="-fx-background-color: #ed0902; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand;" text="B" wrapText="true" />
        <Button fx:id="choiceC" onAction="#onChoiceC" prefHeight="50" prefWidth="600" style="-fx-background-color: #fc0903; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand;" text="C" wrapText="true" />
        <Button fx:id="choiceD" onAction="#onChoiceD" prefHeight="50" prefWidth="600" style="-fx-background-color: #f52822; -fx-text-fill: white; -fx-font-size: 13px; -fx-cursor: hand;" text="D" wrapText="true" />

        <Label fx:id="feedbackLabel" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="" />

        <Button fx:id="nextButton" onAction="#onNextQuestion" prefHeight="40" prefWidth="200" style="-fx-background-color: #e10600; -fx-text-fill: white;                        -fx-font-size: 13px; -fx-cursor: hand;" text="Next Question ▶" visible="false" />
    </VBox>

    <VBox fx:id="resultScreen" alignment="CENTER" spacing="16" style="-fx-background-color: #f5f5f5;" visible="false">
        <padding><Insets bottom="40" left="60" right="60" top="40" /></padding>

        <Label style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #e10600;" text="🏁  RACE COMPLETE!" />

        <Separator style="-fx-background-color: #333;" />

        <Label fx:id="finalScoreLabel" style="-fx-font-size: 22px; -fx-text-fill: white; -fx-font-weight: bold;" text="Final Score: 0" />
        <Label fx:id="accuracyLabel" style="-fx-font-size: 14px; -fx-text-fill: #aaaaaa;" text="Accuracy: 0%" />
        <Label fx:id="resultMessageLabel" style="-fx-font-size: 16px; -fx-text-fill: #f39c12; -fx-font-weight: bold;" text="" wrapText="true" />

        <Separator style="-fx-background-color: #333;" />

        <Label fx:id="leaderboardLabel" style="-fx-font-size: 13px; -fx-text-fill: #dddddd;" text="" wrapText="true" />

        <HBox alignment="CENTER" spacing="20">
            <Button onAction="#onPlayAgain" prefHeight="42" prefWidth="160" style="-fx-background-color: #e10600; -fx-text-fill: white;                            -fx-font-size: 13px; -fx-cursor: hand;" text="Play Again" />
            <Button onAction="#onMainMenu" prefHeight="42" prefWidth="160" style="-fx-background-color: #333355; -fx-text-fill: white;                            -fx-font-size: 13px; -fx-cursor: hand;" text="Main Menu" />
        </HBox>
    </VBox>

</StackPane>
